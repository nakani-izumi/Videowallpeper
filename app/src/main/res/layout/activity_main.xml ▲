<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO WALLPAPER"
            android:textSize="26sp"
            android:textColor="#FF3333"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by Dawson"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="36dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#161616"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIDEO MP4"
                    android:textColor="#FF3333"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_video_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aucune video selectionnee"
                    android:textColor="#CCCCCC"
                    android:textSize="15sp"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btn_pick_video"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Choisir un fichier MP4"
                    android:backgroundTint="#FF3333"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#161616"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Figer la derniere frame"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="La video joue une fois puis se fige. Reprend au reboot."
                        android:textColor="#777777"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_freeze"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_set_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="DEFINIR — ECRAN D'ACCUEIL"
            android:backgroundTint="#FF3333"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_set_lock"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="DEFINIR — ECRAN VERROUILLAGE"
            android:backgroundTint="#1E1E1E"
            android:textColor="#FF3333"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="L'ecran de verrouillage utilise la derniere frame en image statique. La video reprend automatiquement a chaque reboot."
            android:textColor="#444444"
            android:textSize="11sp"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
